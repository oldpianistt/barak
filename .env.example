# Database Configuration
DB_NAME=mermer_gallery
DB_USERNAME=postgres
DB_PASSWORD=change_me_in_production
DB_PORT=5432

# Backend Configuration
BACKEND_PORT=8081
MAX_FILE_SIZE=10MB
MAX_REQUEST_SIZE=10MB

# JPA Configuration (production recommended values)
DDL_AUTO=validate
SHOW_SQL=false
FORMAT_SQL=false

# Frontend Configuration
FRONTEND_PORT=80

# IMPORTANT: 
# 1. Copy this file to .env: cp .env.example .env
# 2. Update DB_PASSWORD with a strong password
# 3. Never commit .env file to version control
